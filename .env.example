# ── FitFinder AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# Never commit the real .env file to version control.

# ── Required: AI Vision ────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# ── Required: Product Search ───────────────────────────────────────────────────
# Get your key at https://serpapi.com  (100 free searches/month)
SERP_API_KEY=your_serpapi_key_here

# ── Optional: Extra product search coverage via RapidAPI ──────────────────────
# Sign up at https://rapidapi.com — search for "Real-Time Product Search"
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Optional: Currency conversion ─────────────────────────────────────────────
# Not required — the service uses built-in fallback rates if this is absent.
# Free tier available at https://exchangerate-api.com
EXCHANGE_RATE_API_KEY=your_exchange_rate_key_here

# ── Development / demo mode ────────────────────────────────────────────────────
# Set to true to use built-in mock data (no API keys required)
USE_MOCK_DATA=false

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_PATH=database/preferences.db

# ── Service ports (change only if defaults conflict with other apps) ───────────
API_GATEWAY_PORT=5000
IMAGE_SERVICE_PORT=5001
SEARCH_SERVICE_PORT=5002
COMPARISON_SERVICE_PORT=5003
RECOMMENDATION_SERVICE_PORT=5004
PREFERENCE_SERVICE_PORT=5005
